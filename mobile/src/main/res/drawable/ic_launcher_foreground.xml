<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Shield Glow behind the shield -->
    <path
        android:pathData="M 54,54 m -36,0 a 36,36 0 1,1 72,0 a 36,36 0 1,1 -72,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="36"
                android:type="radial">
                <item android:offset="0.0" android:color="#307A60FF" />
                <item android:offset="0.8" android:color="#007A60FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Logo Scaled to 64dp centered in 108dp -->
    <!-- Scale = 64/24 = 2.66. Translate = (108-64)/2 = 22 -->
    <group
        android:name="logo_group"
        android:translateX="22"
        android:translateY="22"
        android:scaleX="2.66"
        android:scaleY="2.66">

        <!-- Outer Shield Layer with metallic gradient -->
        <path
            android:pathData="M12,1L3,5v6c0,5.55 3.84,10.74 9,12 5.16,-1.26 9,-6.45 9,-12V5l-9,-4z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="3"
                    android:startY="1"
                    android:endX="21"
                    android:endY="23"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#C0B3FF" />
                    <item android:offset="0.5" android:color="#7A60FF" />
                    <item android:offset="1.0" android:color="#4F38DF" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Inner Glassmorphic Shield Inset -->
        <path
            android:fillColor="#15102A"
            android:pathData="M12,2.5L4.5,6v5c0,4.8 3.2,9.3 7.5,10.5 4.3,-1.2 7.5,-5.7 7.5,-10.5V6l-7.5,-3.5z"/>

        <!-- Sun / Morning Glow with radiant golden gradient -->
        <path
            android:pathData="M12,15c-1.66,0 -3,-1.34 -3,-3s1.34,-3 3,-3s3,1.34 3,3S13.66,15 12,15z M12,7V5 M12,19v-2 M5,12H3 M21,12h-2 M18.36,5.64l-1.41,1.41 M7.05,16.95l-1.41,1.41 M18.36,18.36l-1.41,-1.41 M7.05,7.05L5.64,5.64">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="8"
                    android:startY="5"
                    android:endX="16"
                    android:endY="19"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#FFF3A1" />
                    <item android:offset="0.6" android:color="#FFB33B" />
                    <item android:offset="1.0" android:color="#FF7F11" />
                </gradient>
            </aapt:attr>
        </path>
    </group>
</vector>
