    <string name="onboarding_subtitle_1">Protect your morning brain</string>
    <string name="onboarding_desc_1">MornShield creates a friction-free buffer space for your brain during the first 15-30 minutes of the day, shielding you from immediate digital distractions.</string>
    <string name="onboarding_title_2">Ecosystem Sync</string>
    <string name="onboarding_subtitle_2">Sensing, Anchoring, and Shielding</string>
    <string name="onboarding_desc_2">Wear OS senses sleep stages to wake you up in REM sleep. Android TV hosts an ambient task screensaver, and your Mobile blocks incoming spam notifications.</string>
    <string name="onboarding_title_3">Notification Shield</string>
    <string name="onboarding_subtitle_3">Silence Gmail, Slack &amp; Socials</string>
    <string name="onboarding_desc_3">When the waking sequence begins, distracting notifications are blocked in-memory. Enable \'Notification Listener Access\' so MornShield can protect your morning.</string>
