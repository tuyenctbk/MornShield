<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="320dp"
    android:height="180dp"
    android:viewportWidth="320"
    android:viewportHeight="180">

    <!-- Cinematic Backdrop -->
    <path
        android:pathData="M0,0h320v180h-320z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="160"
                android:startY="0"
                android:endX="160"
                android:endY="180"
                android:type="linear">
                <item android:offset="0.0" android:color="#1A1535" />
                <item android:offset="1.0" android:color="#05040D" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Morning Glow Bloom -->
    <path
        android:pathData="M 0,180 m 0,0 a 140,140 0 0,1 140,-140"
        android:fillAlpha="0.15">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="0"
                android:centerY="180"
                android:gradientRadius="140"
                android:type="radial">
                <item android:offset="0.0" android:color="#FFFFD700" />
                <item android:offset="1.0" android:color="#00FF8C00" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Content Group -->
    <group
        android:translateX="30"
        android:translateY="65">

        <!-- Shield Icon -->
        <group
            android:scaleX="2.8"
            android:scaleY="2.8">
            <path
                android:fillColor="#FF7A60FF"
                android:pathData="M12,2L4,6v6c0,5.55 3.84,10.74 9,12c5.16,-1.26 9,-6.45 9,-12V6l-8,-4z"/>
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M12,12m-3,0a3,3 0 1,1 6,0a3,3 0 1,1 -6,0"
                android:fillAlpha="0.8"/>
        </group>

        <!-- MornShield Branding (Minimalist Accent) -->
        <group android:translateX="85" android:translateY="20">
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M0,0h80v2h-80z"
                android:fillAlpha="0.5"/>
        </group>
    </group>

    <!-- Background Sparkles -->
    <path android:pathData="M280,30h1v1h-1z M300,70h1v1h-1z M260,140h1v1h-1z" android:fillColor="#40FFFFFF"/>

</vector>
