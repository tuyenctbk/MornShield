<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Deep Base -->
    <path
        android:pathData="M0,0h108v108h-108z"
        android:fillColor="#0C091A"/>

    <!-- Nebula Shield 1 -->
    <path
        android:pathData="M 40,40 m -50,0 a 50,50 0 1,1 100,0 a 50,50 0 1,1 -100,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="40"
                android:centerY="40"
                android:gradientRadius="70"
                android:type="radial">
                <item android:offset="0.0" android:color="#257A60FF" />
                <item android:offset="0.7" android:color="#057A60FF" />
                <item android:offset="1.0" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Nebula Shield 2 -->
    <path
        android:pathData="M 80,70 m -60,0 a 60,60 0 1,1 120,0 a 60,60 0 1,1 -120,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="80"
                android:centerY="70"
                android:gradientRadius="80"
                android:type="radial">
                <item android:offset="0.0" android:color="#15C0B3FF" />
                <item android:offset="0.8" android:color="#02C0B3FF" />
                <item android:offset="1.0" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Geometric Shield Field (Subtle) -->
    <path
        android:pathData="M 54,54 m -40,0 a 40,40 0 1,1 80,0 a 40,40 0 1,1 -80,0"
        android:strokeWidth="0.3"
        android:strokeColor="#20C0B3FF"
        android:fillAlpha="0"/>

    <path
        android:pathData="M 54,54 m -45,0 a 45,45 0 1,1 90,0 a 45,45 0 1,1 -90,0"
        android:strokeWidth="0.2"
        android:strokeColor="#10C0B3FF"
        android:fillAlpha="0"/>

</vector>
